{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py" 
    }
  ],
  "headers": [
    {
      "source": "/nathansecurity\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
